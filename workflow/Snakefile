rule download_VEP_cache:
    output:
        directory(".vep_cache/homo_sapiens"),
        ".vep_cache/download_complete_GRCh38.txt" if str(config["ref_genome_version"]).lower()=="grch38" else ".vep_cache/download_complete_GRCh37.txt"
