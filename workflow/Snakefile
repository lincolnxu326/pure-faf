    shell:
        """
        echo "----------------------------------------------" >> {log} 2>&1 &&
        echo "----------------------------------------------" >> {log} 2>&1 &&
        date >> {log} 2>&1 &&
        
        bcftools concat  --write-index --allow-overlaps --rm-dups none -Oz -o {output.v} {input.high_v} {input.low_v} >> {log} 2>&1
        """

