onstart:
    print("\n--- Welcome! ---\n")
    print("\n--- This is pure-faf! - Purification through formalin artefact filtering ---\n")


onsuccess:
    print("\n--- pure-faf finished! ---\n")


onerror:
    print("\n--- What a faf! An error occurred! ---\n")

# wildcard constraints
# -----------------------------------------------------
WILDCARD_CONSTRAINTS = {
    "tum": "|".join(samples["tumour_name"])
}
wildcard_constraints:
    tum=WILDCARD_CONSTRAINTS["tum"]


# target rules
# -----------------------------------------------------
rule all:
    input:
        f"{ODIR}/ffpe_sig/cosine_similarity_repaired_ffpe_sig.tsv",
        f"{ODIR}/ffpe_sig/cosine_similarity_unrepaired_ffpe_sig.tsv",
        f"{ODIR}/ffpe_sig/cosine_similarity_plot_repaired.pdf",
        f"{ODIR}/ffpe_sig/cosine_similarity_plot_unrepaired.pdf"
    default_target: True


# Reorder Mutect2 vcf to have normal sample first, tumour sample secod
# because some of the later steps depend on this order
# -----------------------------------------------------
rule reorder_Mutect2_vcf:
    input:get_mutect2_vcf
    output:
        temp(f"{ODIR}/temp/1-reordered_{{tum}}.vcf.gz"),
        temp(f"{ODIR}/temp/1-reordered_{{tum}}.vcf.gz.csi")
    conda:
        "envs/bcftools.yaml"
    resources:
        mem_mb=4000,
        slurm_cpus_per_task=1
    threads:1
    params:
        normal_name=get_normal_name
    log:
        f"{ODIR}/logs/1-reorder_{{tum}}.log"
    shell:
        """
        echo "----------------------------------------------" >> {log} 2>&1 &&
        echo "----------------------------------------------" >> {log} 2>&1 &&
        date >> {log} 2>&1 &&
        bcftools view -s {params.normal_name},{wildcards.tum} --write-index -Oz -o {output[0]} {input} >> {log} 2>&1
        """

# Normalize vcf, fix a bug in vcf tag, and index the vcf
# This is to ensure every line in the vcf has only one alt allele
# -----------------------------------------------------
rule vcf_normalise:
    input:
        f"{ODIR}/temp/1-reordered_{{tum}}.vcf.gz.csi",
        v=f"{ODIR}/temp/1-reordered_{{tum}}.vcf.gz"
    output:
        v_temp=temp(f"{ODIR}/temp/2-norm_{{tum}}.vcf"),
        v=temp(f'{ODIR}/temp/2-norm_{{tum}}.vcf.gz'),
        i=temp(f'{ODIR}/temp/2-norm_{{tum}}.vcf.gz.csi')
    conda:
        "envs/bcftools.yaml"
    resources:
        mem_mb=4000,
        slurm_cpus_per_task=1
    threads:1 
    log:
        f"{ODIR}/logs/2-vcf_normalise_{{tum}}.log"
    shell:
        """
        echo "----------------------------------------------" >> {log} 2>&1 &&
        echo "----------------------------------------------" >> {log} 2>&1 &&
        date >> {log} 2>&1 &&
        bcftools norm -m -any {input.v} 2> {log} \
        | sed 's/##INFO=<ID=AS_FilterStatus,Number=A/##INFO=<ID=AS_FilterStatus,Number=1/' \
        > {output.v_temp} 2>> {log} &&
        bcftools view --write-index -Oz -o {output.v} {output.v_temp} >> {log} 2>&1
        """

# Annotate VCF files with BETA shape parameters from FFPE PON
# -----------------------------------------------------
rule pon_annotate:
    """
    Annotate vcf with FFPE PON
    """
    input:
        v=f'{ODIR}/temp/2-norm_{{tum}}.vcf.gz',
        i=f'{ODIR}/temp/2-norm_{{tum}}.vcf.gz.csi',
        header= "resources/header.hdr",
        pon=get_PON
    output:
        v=f"{ODIR}/PON/1-{{tum}}_PON_annotated.vcf.gz",
        i=f"{ODIR}/PON/1-{{tum}}_PON_annotated.vcf.gz.csi"
    resources:
        mem_mb=4000,
        slurm_cpus_per_task=1
    threads:1 
    conda:
        "envs/bcftools.yaml"
    log:
        f"{ODIR}/logs/3-pon_annotate_{{tum}}.log"
    shell:
        """
        echo "----------------------------------------------" >> {log} 2>&1 &&
        echo "----------------------------------------------" >> {log} 2>&1 &&
        date >> {log} 2>&1 &&
        bcftools annotate \
            --write-index \
            -a {input.pon} \
            -c CHROM,FROM,TO,INFO/BETA,INFO/FRACTION \
            -h {input.header} \
            {input.v} -Oz -o {output.v} >> {log} 2>&1
        """

# test whether the allelic frequency of the alternate allele in the VCF fits
# the distribution of the allelic frequencies in the PON
# SAMPLE ORDER MATTERS
# normal first, tumour second.
# -----------------------------------------------------
rule test_beta_dist: 
    input:
        v=f"{ODIR}/PON/1-{{tum}}_PON_annotated.vcf.gz",
        i=f"{ODIR}/PON/1-{{tum}}_PON_annotated.vcf.gz.csi"
    output:
        temp_v=temp(f"{ODIR}/PON/2-{{tum}}_beta_dist_tested.vcf"),
        v=f"{ODIR}/PON/2-{{tum}}_beta_dist_tested.vcf.gz",
        i=f"{ODIR}/PON/2-{{tum}}_beta_dist_tested.vcf.gz.csi"
    resources:
        mem_mb=4000,
        slurm_cpus_per_task=1
    threads:1 
    conda:
        "envs/test_beta.yaml"
    log:
        f"{ODIR}/logs/4-beta_dist_test_{{tum}}.log"
    shell:
        """
        echo "----------------------------------------------" >> {log} 2>&1 &&
        echo "----------------------------------------------" >> {log} 2>&1 &&
        date >> {log} 2>&1 &&
        python workflow/scripts/test_pon_betadist_from_normal_first_tumour_second_vcf.py {input.v} {output.temp_v} >> {log} 2>&1 && \
        bcftools view  --write-index -Oz -o {output.v} {output.temp_v} >> {log} 2>&1
        """
# Filter vcf based on quality metrics
# Variants are kept if 
#AD> <threshold> & ROQ> <threshold> & DP> <threshold> & FILTER is PASS or clustered_events or on panel_of_normals & p_ADfit < <threshold>
# -----------------------------------------------------
rule qual_filter:
    input:
        f'{ODIR}/PON/2-{{tum}}_beta_dist_tested.vcf.gz.csi',
        v=f'{ODIR}/PON/2-{{tum}}_beta_dist_tested.vcf.gz'
    output:
        v=f'{ODIR}/PON/3-filtered_{{tum}}.vcf.gz',
        i=f'{ODIR}/PON/3-filtered_{{tum}}.vcf.gz.csi'
    params:
        AD=AD,
        ROQ=ROQ,
        PON_ALPHA=PON_ALPHA,
        DP=DP
    conda:
        "envs/bcftools.yaml"
    threads: 1
    resources:
        mem_mb=4000,
        slurm_cpus_per_task=1
    log:
        f"{ODIR}/logs/5-quality_filter_{{tum}}.log"
    shell:
        """
        echo "----------------------------------------------" >> {log} 2>&1 &&
        echo "----------------------------------------------" >> {log} 2>&1 &&
        date >> {log} 2>&1 &&
        bcftools view --write-index \
        -i '(FORMAT/DP[1]>{params.DP} && INFO/ROQ>{params.ROQ} && FMT/AD[1:1]>{params.AD}) && (INFO/p_ADfit < {params.PON_ALPHA} || INFO/p_ADfit = ".") && (FILTER="PASS" || FILTER="clustered_events" || FILTER="panel_of_normals" || FILTER="clustered_events;panel_of_normals" || FILTER="panel_of_normals;clustered_events")' \
        -Oz -o {output.v} {input.v} >> {log} 2>&1
        """

# Intersect Mutect2 PON filtered VCF with DeepSomatic VCF (position based),
# annotate Mutect2 with DeepSomatic FILTER as INFO/DS_FILTER, then split into SNVs and INDELs
# -----------------------------------------------------
rule DeepSomatic_intersect:
    input:
        m2_PON_filt = f"{ODIR}/PON/3-filtered_{{tum}}.vcf.gz",
        i0          = f"{ODIR}/PON/3-filtered_{{tum}}.vcf.gz.csi",
        deepsomatic = get_deepsomatic_vcf,
        ref         = REF_GEN
    output:
        SNV_intersect_DS   = f"{ODIR}/temp/3-SNV_DeepSomatic_intersect_{{tum}}.vcf.gz",
        i1                 = f"{ODIR}/temp/3-SNV_DeepSomatic_intersect_{{tum}}.vcf.gz.csi",
        INDEL_intersect_DS = f"{ODIR}/temp/3-INDEL_DeepSomatic_intersect_{{tum}}.vcf.gz",
        i2                 = f"{ODIR}/temp/3-INDEL_DeepSomatic_intersect_{{tum}}.vcf.gz.csi",

        # intermediates for record keeping
        m2_norm            = f"{ODIR}/temp/3-DeepSomatic_{{tum}}.m2.norm.vcf.gz",
        m2_norm_csi        = f"{ODIR}/temp/3-DeepSomatic_{{tum}}.m2.norm.vcf.gz.csi",
        ds_norm            = f"{ODIR}/temp/3-DeepSomatic_{{tum}}.ds.norm.vcf.gz",
        ds_norm_csi        = f"{ODIR}/temp/3-DeepSomatic_{{tum}}.ds.norm.vcf.gz.csi",

        m2_pos_bed         = f"{ODIR}/temp/3-DeepSomatic_{{tum}}.m2.pos.bed",
        ds_map             = f"{ODIR}/temp/3-DeepSomatic_{{tum}}.ds.filter.tsv.gz",
        ds_map_tbi         = f"{ODIR}/temp/3-DeepSomatic_{{tum}}.ds.filter.tsv.gz.tbi",
        match_bed          = f"{ODIR}/temp/3-DeepSomatic_{{tum}}.match.bed",

        m2_intersect       = f"{ODIR}/temp/3-DeepSomatic_{{tum}}.m2.intersect.vcf.gz",
        m2_intersect_csi   = f"{ODIR}/temp/3-DeepSomatic_{{tum}}.m2.intersect.vcf.gz.csi",

        anno               = f"{ODIR}/temp/3-DeepSomatic_{{tum}}.m2.ds_annotated.vcf.gz",
        anno_csi           = f"{ODIR}/temp/3-DeepSomatic_{{tum}}.m2.ds_annotated.vcf.gz.csi"
    conda:
        "envs/bcftools.yaml"
    threads: 8
    resources:
        mem_mb=16000,
        slurm_cpus_per_task=8
    log:
        f"{ODIR}/logs/6-DeepSomatic_intersect_{{tum}}.log"
    shell:
        r"""
        echo "----------------------------------------------" >> {log} 2>&1 &&
        echo "----------------------------------------------" >> {log} 2>&1 &&
        date >> {log} 2>&1 &&

        set -euo pipefail
        export LC_ALL=C

        # 1) Normalise both VCFs
        bcftools norm --threads {threads} -f {input.ref} -m -any -Oz -o {output.m2_norm} {input.m2_PON_filt} >> {log} 2>&1 &&
        bcftools index -f -c {output.m2_norm} >> {log} 2>&1 &&

        bcftools norm --threads {threads} -f {input.ref} -m -any -Oz -o {output.ds_norm} {input.deepsomatic} >> {log} 2>&1 &&
        bcftools index -f -c {output.ds_norm} >> {log} 2>&1 &&

        # 2) BED of Mutect2 positions
        bcftools query -f '%CHROM\t%POS\n' {output.m2_norm} \
        | awk 'BEGIN{{OFS="\t"}}{{print $1,$2-1,$2}}' \
        | sort -k1,1 -k2,2n -u > {output.m2_pos_bed} 2>> {log} &&

        # 3) DeepSomatic mapping at Mutect2 positions (CHROM POS DS_FILTER)
        bcftools view -R {output.m2_pos_bed} {output.ds_norm} -Ou \
        | bcftools query -f '%CHROM\t%POS\t%FILTER\n' \
        | sort -k1,1 -k2,2n \
        | awk 'BEGIN{{OFS="\t"}}{{
                key=$1 FS $2;
                if(key!=prev && NR>1){{print pchr,ppos,best}}
                if(key!=prev){{pchr=$1; ppos=$2; best=$3}}
                else if($3=="PASS"){{best="PASS"}}
                prev=key
            }}
            END{{if(NR>0) print pchr,ppos,best}}' \
        | bgzip -c > {output.ds_map} 2>> {log} &&

        tabix -f -s1 -b2 -e2 {output.ds_map} >> {log} 2>&1 &&

        # 4) Keep match_bed for record keeping only (no longer used to subset Mutect2)
        zcat {output.ds_map} \
        | awk 'BEGIN{{OFS="\t"}}{{print $1,$2-1,$2}}' \
        | sort -k1,1 -k2,2n -u > {output.match_bed} 2>> {log} &&

        # 4b) "m2_intersect" is now just all Mutect2 (post-norm), kept for backwards compatibility
        cp -f {output.m2_norm} {output.m2_intersect} >> {log} 2>&1 &&
        bcftools index -f -c {output.m2_intersect} >> {log} 2>&1 &&

        # 5) Annotate Mutect2 with DeepSomatic FILTER as INFO/DS_FILTER (left-join by position)
        bcftools annotate --threads {threads} \
        -a {output.ds_map} \
        -c CHROM,POS,INFO/DS_FILTER \
        -h <(printf '%s\n' '##INFO=<ID=DS_FILTER,Number=1,Type=String,Description="DeepSomatic FILTER status at this position (PASS, RefCall, LowQual, NoCall, GERMLINE). Missing means not present in DeepSomatic. Annotated by position only.">') \
        --write-index -Oz -o {output.anno} {output.m2_intersect} >> {log} 2>&1 &&

        # 6) Split into SNVs and INDELs
        bcftools view --threads {threads} -v snps   --write-index -Oz -o {output.SNV_intersect_DS}   {output.anno} >> {log} 2>&1 &&
        bcftools view --threads {threads} -v indels --write-index -Oz -o {output.INDEL_intersect_DS} {output.anno} >> {log} 2>&1
        """

# Filter DeepSomatic intersected SNVs using VAF
# -----------------------------------------------------
rule SNV_DeepSomatic_intersect_Filtered:
    input:
        snv  = f"{ODIR}/temp/3-SNV_DeepSomatic_intersect_{{tum}}.vcf.gz",
        i1 = f"{ODIR}/temp/3-SNV_DeepSomatic_intersect_{{tum}}.vcf.gz.csi"
    output:
        snv_filtered  = f"{ODIR}/temp/4-SNV_DeepSomatic_intersect_Filtered_{{tum}}.vcf.gz",
        i2 = f"{ODIR}/temp/4-SNV_DeepSomatic_intersect_Filtered_{{tum}}.vcf.gz.csi",
        # record keeping
        filt_counts = f"{ODIR}/temp/4-SNV_DeepSomatic_intersect_Filtered_{{tum}}.filter_counts.txt",
        ds_counts   = f"{ODIR}/temp/4-SNV_DeepSomatic_intersect_Filtered_{{tum}}.ds_filter_counts.txt"
    conda:
        "envs/bcftools.yaml"
    threads: 4
    resources:
        mem_mb=16000,
        slurm_cpus_per_task=4
    log:
        f"{ODIR}/logs/7-DeepSomatic_SNV_filter_{{tum}}.log"
    shell:
        r"""
        echo "----------------------------------------------" >> {log} 2>&1 &&
        echo "----------------------------------------------" >> {log} 2>&1 &&
        date >> {log} 2>&1 &&

        set -euo pipefail
        export LC_ALL=C

        # Keep criteria (Tumour is sample index 1; AF is Number=A so use AF[1:0]):
        # 1) Mutect2 FILTER == clustered_events: keep only if VAF > 10%
        # 2) Mutect2 FILTER == PASS or panel_of_normal and VAF > 5%: keep (DeepSomatic not required)
        # 3) Mutect2 FILTER == PASS or panel_o_normal and 1% < VAF <= 5%: keep only if INFO/DS_FILTER == PASS
        EXPR='(
        (FILTER="clustered_events" || FILTER="clustered_events;panel_of_normals" || FILTER="panel_of_normals;clustered_events")
        && FMT/AF[1:0] > 0.10
        )
        ||
        (
        (FILTER="PASS" || FILTER="panel_of_normals")
        && FMT/AF[1:0] > 0.05
        )
        ||
        (
        (FILTER="PASS" || FILTER="panel_of_normals")
        && FMT/AF[1:0] > 0.01 && FMT/AF[1:0] <= 0.05
        && INFO/DS_FILTER="PASS"
        )'

        bcftools view --write-index -Oz -o {output.snv_filtered} -i "$EXPR" {input.snv} >> {log} 2>&1

        bcftools query -f '%FILTER\n' {output.snv_filtered} \
          | sort | uniq -c | sort -nr > {output.filt_counts} 2>> {log} &&

        bcftools query -f '%INFO/DS_FILTER\n' {output.snv_filtered} \
          | sort | uniq -c | sort -nr > {output.ds_counts} 2>> {log}
        """

# Install MutationalPatterns and the reference-specific BSgenome into a workflow-local R library.
# -------------------------------------------------------------------------------------------------

rule install_indel_deepsomatic_prereqs:
    output:
        done=bsgenome_prereq()
    params:
        ref_genome=str(config["ref_genome_version"]).lower(),
    conda:
        "envs/indel_ffpe_sig.yaml"
    threads: 4
    resources:
        mem_mb=16000,
        slurm_cpus_per_task=4
    log:
        f"{ODIR}/logs/8.0-install_indel_deepsomatic_prereqs.log"
    shell:
        r"""
        echo "----------------------------------------------" >> {log} 2>&1
        echo "----------------------------------------------" >> {log} 2>&1
        date >> {log} 2>&1

        Rscript --vanilla workflow/scripts/install_mutationalpatterns_bsgenome.R \
          --ref {params.ref_genome} 

        # sentinel
        touch {output.done} >> {log} 2>&1
        """



# Filter DeepSomatic intersected INDELs with VAF and using muttype (r-MutationalPatterns)
# -----------------------------------------------------
rule INDEL_DeepSomatic_intersect_Filtered:
    input:
        v=f"{ODIR}/temp/3-INDEL_DeepSomatic_intersect_{{tum}}.vcf.gz",
        i=f"{ODIR}/temp/3-INDEL_DeepSomatic_intersect_{{tum}}.vcf.gz.csi",
        prereq=bsgenome_prereq()
    output:
        v=f"{ODIR}/temp/4-INDEL_DeepSomatic_intersect_Filtered_{{tum}}.vcf.gz",
        i=f"{ODIR}/temp/4-INDEL_DeepSomatic_intersect_Filtered_{{tum}}.vcf.gz.csi",
        report=f"{ODIR}/temp/4-INDEL_DeepSomatic_intersect_Filtered_{{tum}}.report.tsv"
    conda:
